# ── API Gateway ───────────────────────────────────────────────────────────────
# Single nginx gateway that proxies to all backend microservices.
# Dev: http://localhost:3000/api/v1
# Prod: https://api.lipaeasygo.com/api/v1
VITE_API_URL=http://localhost:3000/api/v1

# ── Auth mode ─────────────────────────────────────────────────────────────────
# "dev"  → role picker login, no Cognito required
# ""     → production Cognito Hosted UI redirect
VITE_AUTH_MODE=dev

# ── AWS Cognito (production only) ─────────────────────────────────────────────
VITE_COGNITO_DOMAIN=auth.lipaeasygo.com
VITE_COGNITO_CLIENT_ID=your-cognito-client-id
